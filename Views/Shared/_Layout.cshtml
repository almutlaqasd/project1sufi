@inject IncidentRegistrationMvc.Services.IClientConfigurationService ClientConfigurationService
@{
    var clientConfiguration = await ClientConfigurationService.GetClientConfigurationAsync();
    var appTitle = clientConfiguration.ProjectTitle;
    bool isLoggedIn = Context.Session.GetString("IsLoggedIn") == "true";
    string? userType = Context.Session.GetString("UserType");
    bool isAdmin = isLoggedIn && new[] { "Admin", "SuperAdmin" }.Contains(userType, StringComparer.OrdinalIgnoreCase);
    bool isSuperAdmin = isLoggedIn && string.Equals(userType, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
    string username = Context.Session.GetString("Username") ?? "Guest";
    string[] usernameParts = username.Split(new[] { ' ', '.', '_', '-' }, StringSplitOptions.RemoveEmptyEntries);
    string userInitials = usernameParts.Length > 1
        ? string.Concat(usernameParts.Take(2).Select(x => char.ToUpperInvariant(x[0])))
        : username[..Math.Min(2, username.Length)].ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @appTitle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
<div class="app-shell">
    <aside class="app-sidebar" id="appSidebar" aria-label="Primary navigation">
        <button class="sidebar-close" type="button" aria-label="Close navigation" data-sidebar-close>
            <span aria-hidden="true">&times;</span>
        </button>
        <a class="brand" asp-controller="@(isLoggedIn ? "Registration" : "Account")" asp-action="@(isLoggedIn ? "Create" : "Login")">
            <span class="brand-mark">H</span>
            <span>
                <strong>Hospital CMMS</strong>
                <small>@(clientConfiguration.ClientName ?? "Maintenance Desk")</small>
            </span>
        </a>

        <nav class="app-nav">
            @if (isLoggedIn)
            {
                @if (!isAdmin)
                {
                    <a asp-controller="Registration" asp-action="Create">Registration</a>
                }
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a asp-controller="Dashboard" asp-action="Reports">Reports</a>
                <a asp-controller="Communications" asp-action="Index">Messages</a>
            }
            @if (isAdmin)
            {
                <div class="nav-section">Administration</div>
                <a asp-controller="ConfigureClients" asp-action="Index">Client Configuration</a>
                <a asp-controller="Users" asp-action="Index">Users</a>
                <a asp-controller="LocationMachineMasters" asp-action="Index">Machine Master</a>
                @if (isSuperAdmin) { <a asp-controller="ActivityLogs" asp-action="Audit">All Activity</a> }
                @* <div class="nav-section">Activity</div>
                <a asp-controller="ActivityLogs" asp-action="Users">User Activity</a>
                <a asp-controller="ActivityLogs" asp-action="AccessRights">Access Rights Activity</a> *@
            }
        </nav>
    </aside>

    <main class="app-main">
        <header class="topbar">
            <div class="topbar-heading">
                <button class="sidebar-toggle" type="button" aria-label="Open navigation" aria-controls="appSidebar" aria-expanded="false" data-sidebar-toggle>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </button>
                <div>
                    <span class="eyebrow">@ViewData["Title"]</span>
                    <h1>@appTitle</h1>
                </div>
            </div>
            <div class="topbar-actions">
                @if (isLoggedIn)
                {
                <div class="dropdown">
                    <button class="profile-avatar position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open account menu" id="notificationButton">
                        @userInitials
                        <span class="profile-notification-badge" id="notificationCount" hidden>0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end account-menu p-0">
                        <div class="account-menu-header">
                            <span class="profile-avatar profile-avatar-small">@userInitials</span>
                            <div><strong>@username</strong><small>@userType</small></div>
                        </div>
                        <div class="account-menu-title" id="notificationTitle">Notification - 0</div>
                        <div id="notificationList" class="notification-list"></div>
                        <div class="account-menu-footer"><a asp-controller="Account" asp-action="Logout">Logout</a></div>
                    </div>
                </div>
                }
                else
                {
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </header>

        <section class="content-area">
            @RenderBody()
        </section>
    </main>
</div>
<button class="sidebar-backdrop" type="button" aria-label="Close navigation" tabindex="-1" data-sidebar-close></button>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(() => {
    const sidebar = document.getElementById('appSidebar');
    const toggle = document.querySelector('[data-sidebar-toggle]');
    const closeButtons = document.querySelectorAll('[data-sidebar-close]');

    if (!sidebar || !toggle) return;

    const setSidebar = (isOpen) => {
        document.body.classList.toggle('sidebar-open', isOpen);
        toggle.setAttribute('aria-expanded', String(isOpen));
    };

    toggle.addEventListener('click', () => setSidebar(!document.body.classList.contains('sidebar-open')));
    closeButtons.forEach((button) => button.addEventListener('click', () => setSidebar(false)));
    sidebar.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        if (window.innerWidth <= 900) setSidebar(false);
    }));
    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setSidebar(false);
    });
    window.addEventListener('resize', () => {
        if (window.innerWidth > 900) setSidebar(false);
    });
})();
@if (isLoggedIn) { <text>
async function loadNotifications(){
 try { const response=await fetch('@Url.Action("Notifications", "Communications")'); if(!response.ok)return; const items=await response.json(); const count=document.getElementById('notificationCount'), title=document.getElementById('notificationTitle'), list=document.getElementById('notificationList'); count.textContent=items.length; count.hidden=!items.length; title.textContent=`Notification - ${items.length}`; list.innerHTML=items.map(x=>`<a class="dropdown-item text-wrap" href="${x.url||'#'}"><strong>${x.title}</strong><br><small>${x.message}</small></a>`).join(''); list.hidden=!items.length; } catch {}
}
document.getElementById('notificationButton')?.addEventListener('click',async()=>{await fetch('@Url.Action("MarkNotificationsRead", "Communications")',{method:'POST',headers:{'RequestVerificationToken':document.querySelector('input[name="__RequestVerificationToken"]')?.value||''}});});
loadNotifications(); setInterval(loadNotifications,10000);
</text> }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
